# =============================================================================
# Multi-Platform Analytics Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials for each platform
# you want to connect to. Only configure platforms you need.

# -----------------------------------------------------------------------------
# Umami (Web Analytics)
# -----------------------------------------------------------------------------
# Cloud:
UMAMI_URL=https://api.umami.is
UMAMI_API_KEY=your_api_key_here

# Self-hosted with Team:
# UMAMI_URL=https://your-umami-instance.com
# UMAMI_USERNAME=your_username
# UMAMI_PASSWORD=your_password
# UMAMI_TEAM_ID=your-team-id

# Self-hosted (username/password only):
# UMAMI_URL=https://your-umami-instance.com
# UMAMI_USERNAME=admin
# UMAMI_PASSWORD=your_password

# Note: Use one authentication method. The server auto-detects which to use.

# -----------------------------------------------------------------------------
# Google Search Console (Search Performance)
# -----------------------------------------------------------------------------
# Option 1: OAuth (recommended for personal use)
# 1. Run: uv run scripts/gsc_oauth.py
# 2. Authorize in browser
# 3. Token saved to .gsc_token.json
GSC_SITE_URL=https://your-domain.com/
# GSC_TOKEN_FILE=.gsc_token.json  # optional, defaults to .gsc_token.json

# Option 2: Service Account (for orgs without policy restrictions)
# 1. Create Google Cloud project
# 2. Enable Search Console API
# 3. Create service account and download JSON key
# 4. Share GSC property with service account email
# GSC_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json
# GSC_SITE_URL=https://your-domain.com/

# -----------------------------------------------------------------------------
# YouTube (Video Analytics)
# -----------------------------------------------------------------------------
# 1. Create Google Cloud project
# 2. Enable YouTube Data API v3
# 3. Create API key or OAuth credentials
# 4. Get channel ID from YouTube Studio
# YOUTUBE_API_KEY=your_youtube_api_key
# YOUTUBE_CHANNEL_ID=your_channel_id

# -----------------------------------------------------------------------------
# Mastodon (Social Engagement)
# -----------------------------------------------------------------------------
# 1. Register app on your Mastodon instance
# 2. Get access token from settings
# 3. Get account ID from profile
# MASTODON_INSTANCE=mastodon.social
# MASTODON_CLIENT_ID=your_client_id
# MASTODON_CLIENT_SECRET=your_client_secret
# MASTODON_ACCESS_TOKEN=your_access_token
# MASTODON_ACCOUNT_ID=your_account_id

# -----------------------------------------------------------------------------
# Bluesky (Social Engagement)
# -----------------------------------------------------------------------------
# 1. Create app password in Bluesky settings
# BLUESKY_IDENTIFIER=your-handle.bsky.social
# BLUESKY_PASSWORD=your_app_password

# -----------------------------------------------------------------------------
# LinkedIn (Professional Social)
# -----------------------------------------------------------------------------
# 1. Create LinkedIn app
# 2. Get organization admin authorization
# 3. Complete OAuth 2.0 flow
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_ACCESS_TOKEN=your_access_token
# LINKEDIN_ORGANIZATION_ID=your_organization_id

# -----------------------------------------------------------------------------
# Instagram/Threads (Social Engagement)
# -----------------------------------------------------------------------------
# 1. Facebook Developer account required
# 2. Instagram Business account required
# 3. Link Facebook Page
# INSTAGRAM_ACCESS_TOKEN=your_access_token
# INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# -----------------------------------------------------------------------------
# Cloudflare AI (for AI-powered insights)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# -----------------------------------------------------------------------------
# Gemini API (for AI-powered insights)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
